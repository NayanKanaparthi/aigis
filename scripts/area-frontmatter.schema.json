{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aigis area frontmatter schema",
  "description": "YAML frontmatter contract for content/skills/areas/*.md. See docs/frontmatter-schema.md for full semantics.",
  "type": "object",
  "required": ["id", "title", "controls", "min_risk_tier", "system_traits"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Must equal the filename without .md."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "controls": {
      "type": "object",
      "required": ["owasp", "nist", "iso42001"],
      "additionalProperties": false,
      "properties": {
        "owasp": {
          "type": "array",
          "items": { "type": "string", "pattern": "^LLM\\d{2}$" }
        },
        "nist": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(MAP|MEASURE|MANAGE|GOVERN)-\\d+(\\.\\d+)?$" }
        },
        "iso42001": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(Clause-\\d+(\\.\\d+)?|Annex-[A-Z](\\.\\d+)?|Annex-[A-Z])$" }
        },
        "eu_ai_act": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(Art-\\d+(\\([0-9a-z]+\\))*|Annex-[IVX]+(\\([0-9a-z]+\\))*)$"
          },
          "description": "EU AI Act article references. v2.1 addition. Optional."
        }
      }
    },
    "min_risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "all"]
    },
    "system_traits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "jurisdiction": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["eu", "us-regulated"] },
      "description": "Gates which framework controls render in brief. v2.1 addition. Optional. Absence = applies to all jurisdictions."
    }
  }
}

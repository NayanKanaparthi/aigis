{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aigis triggers.json schema",
  "type": "object",
  "required": ["version", "tier_rule", "high_confidence", "low_confidence"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "tier_rule": { "type": "string", "minLength": 50 },
    "high_confidence": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/high_entry" }
    },
    "low_confidence": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/low_entry" }
    }
  },
  "definitions": {
    "high_entry": {
      "type": "object",
      "required": ["traits", "confidence", "notes"],
      "additionalProperties": false,
      "properties": {
        "traits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["high"] },
        "notes": { "type": "string", "minLength": 1 },
        "context_filter": {
          "type": "array",
          "items": { "type": "string", "enum": ["web", "agentic", "rag", "batch"] }
        }
      }
    },
    "low_entry": {
      "type": "object",
      "required": ["traits", "confidence", "confirmation_prompt", "notes"],
      "additionalProperties": false,
      "properties": {
        "traits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["low"] },
        "confirmation_prompt": { "type": "string", "minLength": 20 },
        "notes": { "type": "string", "minLength": 1 },
        "context_filter": {
          "type": "array",
          "items": { "type": "string", "enum": ["web", "agentic", "rag", "batch"] }
        }
      }
    }
  }
}
